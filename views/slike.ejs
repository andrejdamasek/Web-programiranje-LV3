<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Filmska galerija — ikonski vizuali zlatnog doba kinematografije. FilmShare galerija.">
    <meta name="author" content="Andrej">
    <title>Galerija</title>
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="/styles/slike.css">
</head>
<body>

    <header class="site-header">
        <div class="header-inner">
            <div class="logo">
                <h1>FilmShare</h1>
            </div>
        </div>
    </header>

    <nav class="main-nav" aria-label="Glavna navigacija">
        <ul class="nav-menu">
            <li><a href="/">Početna</a></li>
            <li><a href="/grafikon">Statistika</a></li>
            <li><a href="/slike" aria-current="page">Galerija</a></li>
        </ul>
    </nav>

    <main class="gallery-main">

        <div class="gallery-header">
            <h2>Filmovi</h2>
        </div>

        <section class="galerija">
            <% images.forEach(image => { %>
                <figure class="gallery-item">
                    <a href="#<%= image.id %>">
                        <img src="<%= image.url %>" alt="<%= image.title %>" loading="lazy">
                    </a>
                    
                    <figcaption class="movie-title">
                        <%= image.title %>
                    </figcaption>
                </figure>
            <% }); %>
        </section>


        <% images.forEach(image => { %>
        <div id="<%= image.id %>" class="lightbox" role="dialog" aria-modal="true" aria-label="Uvećana slika: <%= image.title %>">
            <a href="#" class="lightbox-overlay" aria-label="Zatvori galeriju"></a>
            <div class="lightbox-content">
                <a href="#" class="close-btn" aria-label="Zatvori">Zatvori ×</a>
                <img 
                    src="<%= image.url %>" 
                    alt="Uvećana verzija: <%= image.title %>"
                >
            </div>
        </div>
        <% }); %>

    </main>

    <footer class="site-footer">
        <p>FilmShare — Premium Arhiva Filmskih Klasika</p>
        <p style="font-size: 0.75rem;">Projekt iz Web Programiranja 2025/2026. Sva prava pridržana.</p>
    </footer>

</body>
</html>

